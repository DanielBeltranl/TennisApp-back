# Base de Datos PostgreSQL
# Con Docker: DB_HOST=db (nombre del servicio en docker-compose)
# En local sin Docker: DB_HOST=localhost
DB_NAME=tennisapp
DB_USER=tennisapp
DB_PASSWORD=tennisapp
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY=cambia_esto_por_una_clave_segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Variables de cálculo de distancia recorrida
# Fuente: .claude/docs/tennis-math-data-and-logic/tennis-math-data-and-logic.md
# Fórmula: D = Tiempo_total_punto × (EFF / 100) × (MPM / 60)
# MPM = promedio del rango Distancia por Minuto de la tabla
# EFF = porcentaje de tiempo efectivo de juego
# Leídas en: back/settings.py → TENNIS_DISTANCE_PARAMS
# =============================================================================

# --- AMATEUR | ARCILLA ---
DIST_AMATEUR_CLAY_M_EFF=23.0
DIST_AMATEUR_CLAY_M_MPM=28.5
DIST_AMATEUR_CLAY_F_EFF=21.0
DIST_AMATEUR_CLAY_F_MPM=25.0

# --- AMATEUR | DURA ---
DIST_AMATEUR_HARD_M_EFF=17.0
DIST_AMATEUR_HARD_M_MPM=34.0
DIST_AMATEUR_HARD_F_EFF=13.0
DIST_AMATEUR_HARD_F_MPM=29.0

# --- SEMI-PRO | ARCILLA ---
DIST_SEMIPRO_CLAY_M_EFF=31.0
DIST_SEMIPRO_CLAY_M_MPM=36.0
DIST_SEMIPRO_CLAY_F_EFF=28.0
DIST_SEMIPRO_CLAY_F_MPM=31.5

# --- SEMI-PRO | DURA ---
DIST_SEMIPRO_HARD_M_EFF=22.0
DIST_SEMIPRO_HARD_M_MPM=43.0
DIST_SEMIPRO_HARD_F_EFF=20.0
DIST_SEMIPRO_HARD_F_MPM=38.0

# --- PROFESIONAL | ARCILLA ---
DIST_PRO_CLAY_M_EFF=40.0
DIST_PRO_CLAY_M_MPM=40.0
DIST_PRO_CLAY_F_EFF=35.0
DIST_PRO_CLAY_F_MPM=37.0

# --- PROFESIONAL | DURA ---
DIST_PRO_HARD_M_EFF=27.0
DIST_PRO_HARD_M_MPM=48.5
DIST_PRO_HARD_F_EFF=25.0
DIST_PRO_HARD_F_MPM=44.0
